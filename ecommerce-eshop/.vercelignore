# Vercel deployment artifacts
.vercel/

# Heavy dev-only files we don't want on Vercel
**/tests/
**/tests/**/*
**/storage/framework/views/*
**/storage/framework/sessions/*
**/storage/framework/cache/data/*
**/storage/logs/*.log
**/storage/app/public/*
!**/storage/app/public/.gitkeep

# Local-only SQLite database files (we use external MySQL on Vercel)
*.sqlite
*.sqlite3

# Local-only scripts (debug helpers, not needed in production)
test_*.php
debug_*.php
view_order_logs.php
check_*.php
fix_admin.php
debug_auth.php
test_hash.php
test_order_creation.php

# Documentation (kept in repo but not deployed)
*.md
!README.md

# Docker files (not used on Vercel)
Dockerfile
docker-entrypoint.sh

# Render config (not used on Vercel)
render.yaml
